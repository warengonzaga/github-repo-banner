{
  "name": "github-repo-banner",
  "version": "1.3.0",
  "description": "Generate customizable GitHub repository banners via URL parameters",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@wgtechlabs/log-engine": "^2.2.0",
    "dotenv": "^17.2.3",
    "hono": "^4.12.14",
    "ioredis": "^5.9.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": "^22"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "packageManager": "bun@1.3.9"
}
